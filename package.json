{
  "name": "ss-image-search",
  "version": "1.0.0",
  "description": "中古アパレル買取 画像類似検索モックアプリ",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild",
    "dist": "electron-vite build && electron-builder --mac --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "seed": "ELECTRON_RUN_AS_NODE=1 ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron ./node_modules/.bin/tsx scripts/seed-mens.ts"
  },
  "build": {
    "appId": "com.ssimagesearch.app",
    "productName": "SS Image Search",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-arm64.${ext}"
    },
    "extraResources": [
      {
        "from": "seed-data",
        "to": "seed-data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "!node_modules/**/*.{md,ts,map}",
      "!node_modules/**/{test,tests,__tests__}/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-image-crop": "^11.0.10",
    "react-router-dom": "^6.26.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
